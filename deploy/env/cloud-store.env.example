# Cloud Store runtime environment
# Copy this file to:
#   /root/cloud-store/cloud-store.env

NODE_ENV=production
HOST=127.0.0.1
PORT=3000

# Current server paths
CLOUD_STORE_DB_PATH=/root/cloud-store/cloud-store.sqlite
CLOUD_STORE_UPLOAD_ROOT=/root/cloud-store/public/uploads

# Set this before first public launch
CS_ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD

# SMS / Account security
# Canonical deploy baseline: staging / public should use aliyun by default.
# Local development only: if you want mock + debug codes, change these values explicitly.
# SignName / TemplateCode should come from the gifted sign/template in the
# 号码认证服务控制台, not the old long-form SMS filing flow.
CS_SMS_PROVIDER=aliyun
CS_SMS_DEBUG_CODES=false
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
# Optional: leave empty to use the default PNVS scheme.
ALIYUN_SMS_SCHEME_NAME=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
# Optional: split gifted template codes by purpose instead of sharing one generic template.
ALIYUN_SMS_TEMPLATE_CODE_BIND_PHONE=
ALIYUN_SMS_TEMPLATE_CODE_LOGIN_OR_REGISTER=
ALIYUN_SMS_TEMPLATE_CODE_RESET_PASSWORD=
# Local development only: keep false for staging / public.
CS_ENABLE_LOCAL_MOCK_PAYMENT=false

# Alipay WAP payment
# Real collection will not work until you complete the Alipay console setup,
# fill the values below, upload to the server, and restart PM2.
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
# Optional: keep empty to use the production gateway default.
ALIPAY_GATEWAY=
# Required when ALIPAY_ENABLED=true: runtime will fail fast if these stay empty.
CLOUD_STORE_PUBLIC_BASE_URL=
ALIPAY_RETURN_URL=
ALIPAY_NOTIFY_URL=
# Optional merchant PID / seller id shown in Alipay console.
ALIPAY_SELLER_ID=

# WeChat H5 / JSAPI payment
# Real collection will not work until you complete the WeChat Pay merchant setup,
# bind the payment domain / callback whitelist, upload certificates, and restart PM2.
WECHAT_PAY_ENABLED=false
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=
# Required when WECHAT_PAY_ENABLED=true: payment page will fail fast if these stay empty.
WECHAT_PAY_INAPP_RETURN_URL=
WECHAT_PAY_EXTERNAL_RETURN_URL=
# Optional: keep empty to use the default gateway endpoints.
WECHAT_PAY_JSAPI_GATEWAY=
WECHAT_PAY_H5_GATEWAY=
