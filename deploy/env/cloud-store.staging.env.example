# Cloud Store staging runtime environment
# Copy this file to:
#   /root/cloud-store-staging/cloud-store.env

NODE_ENV=production
HOST=127.0.0.1
PORT=3001

# Explicit runtime identity for the staging site.
CLOUD_STORE_RUNTIME_ENV=staging
CLOUD_STORE_RUNTIME_LABEL=测试环境 / staging
CLOUD_STORE_PUBLIC_BASE_URL=https://staging.example.com

# Current server paths
CLOUD_STORE_DB_PATH=/root/cloud-store-staging/cloud-store.sqlite
CLOUD_STORE_UPLOAD_ROOT=/root/cloud-store-staging/public/uploads

# Set this before first staging boot
CS_ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD

# SMS / Account security
CS_SMS_PROVIDER=aliyun
CS_SMS_DEBUG_CODES=false
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SCHEME_NAME=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_TEMPLATE_CODE_BIND_PHONE=
ALIYUN_SMS_TEMPLATE_CODE_LOGIN_OR_REGISTER=
ALIYUN_SMS_TEMPLATE_CODE_RESET_PASSWORD=

# Local development only: keep false for staging.
CS_ENABLE_LOCAL_MOCK_PAYMENT=false

# Alipay WAP payment
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=
ALIPAY_RETURN_URL=https://staging.example.com/#/paymentResult
ALIPAY_NOTIFY_URL=https://staging.example.com/api/payments/alipay/notify
ALIPAY_SELLER_ID=

# WeChat H5 / JSAPI payment
WECHAT_PAY_ENABLED=false
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=https://staging.example.com/api/payments/wechat/notify
WECHAT_PAY_INAPP_RETURN_URL=https://staging.example.com/#/paymentResult
WECHAT_PAY_EXTERNAL_RETURN_URL=https://staging.example.com/#/paymentResult
WECHAT_PAY_JSAPI_GATEWAY=
WECHAT_PAY_H5_GATEWAY=
